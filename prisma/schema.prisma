generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  settings      UserSettings?
  projects      Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  defaultLanguage String   @default("ru-RU")
  interfaceMode   String   @default("simple")
  defaultModel    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                 String        @id @default(cuid())
  userId             String?
  name               String
  description        String        @default("")
  targetUsers        String        @default("")
  appGoal            String        @default("")
  platform           String        @default("iOS и Android")
  styleDirection     String        @default("")
  designRequirements String        @default("")
  architectureNotes  String        @default("")
  constraints        String        @default("")
  designSystemSource String        @default("current_library")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  rules              ProjectRule[]
  screens            Screen[]
  designDecisions    DesignDecision[]
  screenSummaries    ScreenSummary[]
  aiPromptLogs       AiPromptLog[]
  designComponents   DesignComponent[]
  designTokens       DesignToken[]
  designAssets       DesignAsset[]
  designPatterns     DesignPattern[]
  designImports      DesignImport[]
  similarityReports  ComponentSimilarityReport[]
  styleReports       StyleSimilarityReport[]
  user               User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectRule {
  id        String   @id @default(cuid())
  projectId String
  category  String
  name      String
  value     String
  source    String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Screen {
  id                String          @id @default(cuid())
  projectId         String
  approvedVersionId String?         @unique
  name              String
  purpose           String          @default("")
  status            String          @default("draft")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions          ScreenVersion[] @relation("ScreenVersions")
  approvedVersion   ScreenVersion?  @relation("ApprovedScreenVersion", fields: [approvedVersionId], references: [id], onDelete: SetNull)
  designDecisions   DesignDecision[]
  summaries         ScreenSummary[]
  aiPromptLogs      AiPromptLog[]

  @@index([projectId])
}

model ScreenVersion {
  id            String   @id @default(cuid())
  screenId      String
  versionNumber Int
  userRequest   String   @default("")
  designSpec    String   @default("")
  imagePrompt   String   @default("")
  changeSummary String   @default("")
  diff          String   @default("")
  newRulesJson  String   @default("[]")
  layoutJson    String?
  htmlLayout    String?
  flutterWidgetTree String?
  createdAt     DateTime @default(now())
  screen        Screen   @relation("ScreenVersions", fields: [screenId], references: [id], onDelete: Cascade)
  approvedForScreen Screen? @relation("ApprovedScreenVersion")
  designDecisions DesignDecision[]
  summaries       ScreenSummary[]
  aiPromptLogs    AiPromptLog[]
  styleSimilarityReport StyleSimilarityReport?

  @@unique([screenId, versionNumber])
  @@index([screenId])
}

model DesignComponent {
  id                    String   @id @default(cuid())
  projectId             String
  name                  String
  description           String   @default("")
  category              String   @default("Misc")
  screenshot            String?
  preview               String?
  layoutJson            String?
  htmlLayout            String?
  flutterWidgetTree     String?
  dimensions            String?
  radius                String?
  colors                String?
  typography            String?
  spacing               String?
  states                String?
  variants              String?
  source                String   @default("manual")
  usageCount            Int      @default(0)
  approved              Boolean  @default(false)
  status                String   @default("draft")
  createdBy             String   @default("user")
  basedOnComponents     String?
  creationReason        String?
  differences           String?
  imagePrompt           String?
  designSpec            String?
  usageGuidelines       String?
  accessibilityNotes    String?
  usedInScreens         String?
  sourceScreenId        String?
  sourceScreenVersionId String?
  lastUsedAt            DateTime?
  screensUsedIn         String?
  projectsUsedIn        String?
  similarityHistory     String?
  editHistory           String?
  approveHistory        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  similarityReports     ComponentSimilarityReport[]

  @@index([projectId, status])
  @@index([projectId, category])
  @@index([sourceScreenVersionId])
}

model DesignToken {
  id        String   @id @default(cuid())
  projectId String
  group     String
  name      String
  value     String
  description String @default("")
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, group, name])
  @@index([projectId, group])
}

model DesignAsset {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  path      String?
  preview   String?
  metadata  String?
  source    String   @default("import")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, type])
}

model DesignPattern {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  category    String
  description String   @default("")
  layoutJson  String?
  componentIds String?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, category])
}

model DesignImport {
  id           String   @id @default(cuid())
  projectId    String
  type         String
  name         String
  sourcePath   String?
  status       String   @default("pending")
  analysisJson String?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, status])
}

model ComponentSimilarityReport {
  id                 String   @id @default(cuid())
  projectId          String
  componentId        String?
  candidateName      String
  score              Float
  recommendation     String
  reasonsJson        String?
  createdAt          DateTime @default(now())
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  component          DesignComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  @@index([projectId, score])
}

model StyleSimilarityReport {
  id              String   @id @default(cuid())
  projectId       String
  screenVersionId String   @unique
  score           Float
  reasonsJson     String?
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  screenVersion   ScreenVersion @relation(fields: [screenVersionId], references: [id], onDelete: Cascade)
  @@index([projectId, score])
}

model DesignDecision {
  id              String   @id @default(cuid())
  projectId       String
  screenId        String?
  screenVersionId String?
  type            String
  target          String
  oldValue        String?
  newValue        String?
  reason          String?
  source          String   @default("ai")
  status          String   @default("proposed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  screen          Screen?  @relation(fields: [screenId], references: [id], onDelete: SetNull)
  screenVersion   ScreenVersion? @relation(fields: [screenVersionId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([screenId])
  @@index([screenVersionId])
}

model ScreenSummary {
  id                String   @id @default(cuid())
  projectId         String
  screenId          String
  screenVersionId   String   @unique
  summary           String
  mainPurpose       String
  primaryUserAction String?
  usedPatterns      String?
  usedRules         String?
  visualNotes       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  screen            Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  screenVersion     ScreenVersion @relation(fields: [screenVersionId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([screenId])
}

model AiPromptLog {
  id              String   @id @default(cuid())
  projectId       String
  screenId        String?
  screenVersionId String?
  action          String
  model           String
  requestPreview  String
  fullPrompt      String
  rawResponse     String?
  parsedResponse  String?
  error           String?
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  screen          Screen?  @relation(fields: [screenId], references: [id], onDelete: SetNull)
  screenVersion   ScreenVersion? @relation(fields: [screenVersionId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([screenId])
  @@index([screenVersionId])
}
